{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "MeroShareBot.Shared.MeroShare.MeroShareLoggingHandler": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Telegram": {
    "ApiUrl": "https://api.telegram.org/bot",
    "BotToken": ""
  },
  "MeroShare": {
    "BaseUrl": "https://webbackend.cdsc.com.np/api",
    "DefaultApplyKitta": 10
  },
  "Security": {
    "DataEncryptionKey": ""
  },
  "Scheduler": {
    "IpoCron": "20 4 * * *"
  }
}
